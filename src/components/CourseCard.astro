---
interface Props {
  title: string;
  description: string;
  image: string;
  href?: string;
}

const { title, description, image, href = '#' } = Astro.props;
---

<div class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-lg card-hover group">
  <a href={href} class="block">
    <div class="aspect-[4/3] overflow-hidden">
      <img src={image} alt={title} class="w-full h-full object-cover img-zoom" loading="lazy" onerror="this.style.display='none'" />
    </div>
    <div class="p-6 text-center">
      <h3 class="text-xl font-bold text-[#1A1A1A]">{title}</h3>
      <p class="mt-2 text-sm text-[#666666] leading-relaxed">{description}</p>
    </div>
  </a>
</div>
