---
interface Props {
  title: string;
  subtitle?: string;
  class?: string;
  light?: boolean;
  align?: 'left' | 'center';
}
const { title, subtitle, class: className = '', light = false, align = 'center' } = Astro.props;

const alignClass = align === 'center' ? 'text-center mx-auto' : 'text-left';
const maxWidthClass = align === 'center' ? 'max-w-3xl' : 'max-w-2xl';
---
<div class={`${alignClass} ${maxWidthClass} mb-12 ${className}`}>
  <h2 class={`text-3xl md:text-4xl lg:text-5xl font-bold ${light ? 'text-white' : 'text-[#1A1A1A]'}`} style="font-family: 'Noto Sans Display', ui-sans-serif, system-ui, sans-serif;">{title}</h2>
  {subtitle && <p class={`mt-4 text-base md:text-lg ${light ? 'text-white/70' : 'text-[#666666]'}`}>{subtitle}</p>}
</div>
