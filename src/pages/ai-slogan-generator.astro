---
import Layout from '@layouts/Layout.astro';
import Button from '@components/Button.astro';
---

<Layout title="AI Slogan Generator - Building a Brand Online" description="Create catchy, memorable slogans for your brand with our upcoming AI-powered generator. Craft taglines that resonate with your audience. Coming soon.">
  <div class="min-h-[80vh] flex items-center justify-center bg-[#F5F5F5]">
    <div class="text-center max-w-xl mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-bold" style="font-family: 'Noto Sans Display', ui-sans-serif, system-ui, sans-serif;">AI Slogan Generator</h1>
      <p class="mt-4 text-xl text-[#666666]">Create memorable slogans for your brand with our upcoming AI-powered slogan generator. Check back soon!</p>
      <div class="mt-8">
        <Button variant="primary-solid" href="/">Back to Home</Button>
      </div>
  </div>
  </div>
</Layout>
