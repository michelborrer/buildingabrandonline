---
import Layout from '@layouts/Layout.astro';
import Button from '@components/Button.astro';
import ScrollReveal from '@components/ScrollReveal.astro';

const siteUrl = 'https://buildingabrandonline.com';
const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Contact', path: '/contact/' },
];
const contactSchema = {
  '@type': 'ContactPage',
  name: 'Contact Building a Brand Online',
  url: `${siteUrl}/contact/`,
  description:
    'Get in touch with the Building a Brand Online team for digital marketing insights, branding support, and course questions.',
  mainEntity: { '@id': `${siteUrl}/#organization` },
};
---

<Layout
  title="Contact Us - Building a Brand Online"
  description="Get in touch with our team for digital marketing insights, branding support, and course questions. We're here to help you build a thriving online brand."
  breadcrumbs={breadcrumbs}
  jsonLd={contactSchema}
>
  <!-- Hero Banner -->
  <section class="relative py-24 md:py-32 bg-[#0A0A0A]">
    <div class="absolute inset-0 bg-gradient-to-br from-[#0A0A0A] via-[#1A1A2E] to-[#16213E]"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white" style="font-family: 'Noto Sans Display', ui-sans-serif, system-ui, sans-serif;">Let's Connect!</h1>
      <p class="mt-6 text-lg text-white/80 max-w-2xl mx-auto">
        We're here to help you build your brand online. Reach out with any questions or inquiries you may have. We'd love to hear from you!
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[45%_55%] gap-12">
        <!-- Left — Contact Info -->
        <ScrollReveal>
          <div>
            <p class="text-sm uppercase tracking-widest text-[#999999] mb-4">Get in Touch</p>
            <h2 class="text-3xl md:text-4xl font-bold text-[#1A1A1A]" style="font-family: 'Noto Sans Display', ui-sans-serif, system-ui, sans-serif;">Contact Us</h2>
            <p class="mt-4 text-[#666666] leading-relaxed">Reach out to us for digital marketing insights and support. We're here to help you build your online brand.</p>

            <div class="flex flex-col gap-6 mt-10">
              <!-- Email -->
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-[#F5F5F5] rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4361EE" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-[#1A1A1A]">Email</p>
                  <a href="mailto:info@buildingabrandonline.com" class="text-[#4361EE] hover:underline">info@buildingabrandonline.com</a>
                </div>
              </div>

              <!-- Phone -->
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-[#F5F5F5] rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4361EE" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-[#1A1A1A]">Phone</p>
                  <a href="tel:+14155550123" class="text-[#4361EE] hover:underline">+1 (415) 555-0123</a>
                </div>
              </div>

              <!-- Address -->
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-[#F5F5F5] rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4361EE" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
                    <circle cx="12" cy="10" r="3"></circle>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-[#1A1A1A]">Address</p>
                  <p class="text-[#666666]">123 Market Street<br>San Francisco, CA 94103</p>
                </div>
              </div>
            </div>
          </div>
        </ScrollReveal>

        <!-- Right — Google Map -->
        <ScrollReveal delay={200}>
          <div class="rounded-lg overflow-hidden shadow-md h-full min-h-[400px]">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3153.0977704983927!2d-122.4064170846822!3d37.78583497975655!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8085807f619a62df%3A0x491ce2f73977af35!2sMarket%20St%2C%20San%20Francisco%2C%20CA!5e0!3m2!1sen!2sus!4v1706745600000!5m2!1sen!2sus"
              width="100%"
              height="100%"
              style="border:0; min-height: 400px;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Office location map"
              class="rounded-lg"
            ></iframe>
          </div>
        </ScrollReveal>
      </div>
    </div>
  </section>
</Layout>
