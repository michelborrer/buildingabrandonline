---
import Layout from '@layouts/Layout.astro';
import ScrollReveal from '@components/ScrollReveal.astro';

const siteUrl = 'https://buildingabrandonline.com';
const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Contact', path: '/contact/' },
];
const contactSchema = {
  '@type': 'ContactPage',
  name: 'Contact Building a Brand Online',
  url: `${siteUrl}/contact/`,
  description:
    'Email the Building a Brand Online team with questions about courses, free resources, branding services, or anything on the blog.',
  mainEntity: { '@id': `${siteUrl}/#organization` },
};

const reasons = [
  {
    title: 'Course & training questions',
    description:
      "Not sure which program fits where you are right now? Tell us about your business and we'll point you to the right starting place — even if that's a free resource instead of a paid course.",
    subject: 'Question about training',
  },
  {
    title: 'Free resource requests',
    description:
      'Every template and guide on our resources page is delivered by email. Tell us which one you want and it will be in your inbox shortly.',
    subject: 'Resource request',
  },
  {
    title: 'Services & partnerships',
    description:
      'Interested in brand strategy work, a workshop for your team, or a collaboration? Give us a short brief and we will reply with honest next steps.',
    subject: 'Services inquiry',
  },
];
---

<Layout
  title="Contact Us - Building a Brand Online"
  description="Email the Building a Brand Online team about courses, free templates, or branding services. A real person replies to every message, usually within one business day."
  breadcrumbs={breadcrumbs}
  jsonLd={contactSchema}
>
  <!-- Hero Banner -->
  <section class="relative py-24 md:py-32 bg-[#0A0A0A]">
    <div class="absolute inset-0 bg-gradient-to-br from-[#0A0A0A] via-[#1A1A2E] to-[#16213E]"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white" style="font-family: 'Noto Sans Display', ui-sans-serif, system-ui, sans-serif;">Talk to a Human</h1>
      <p class="mt-6 text-lg text-white/80 max-w-2xl mx-auto">
        No ticket numbers, no chatbots. Email us and a real person — often Dana herself — will get back to you, usually within one business day.
      </p>
      <div class="mt-8">
        <a href="mailto:info@buildingabrandonline.com" class="inline-block bg-white text-[#0A0A0A] px-6 py-3 rounded-md font-medium hover:bg-gray-100 transition-all duration-200 hover:scale-[1.02]">
          info@buildingabrandonline.com
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Reasons -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <p class="text-sm uppercase tracking-widest text-[#999999] mb-4 text-center">What can we help with?</p>
        <h2 class="text-3xl md:text-4xl font-bold text-[#1A1A1A] text-center" style="font-family: 'Noto Sans Display', ui-sans-serif, system-ui, sans-serif;">Pick a Starting Point</h2>
      </ScrollReveal>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-12">
        {reasons.map((reason, index) => (
          <ScrollReveal delay={index * 100}>
            <div class="bg-[#F5F5F5] rounded-lg p-8 h-full flex flex-col">
              <h3 class="text-xl font-bold text-[#1A1A1A]">{reason.title}</h3>
              <p class="mt-3 text-[#666666] leading-relaxed flex-grow">{reason.description}</p>
              <a
                href={`mailto:info@buildingabrandonline.com?subject=${encodeURIComponent(reason.subject)}`}
                class="mt-6 inline-block text-[#4361EE] font-medium hover:underline"
              >
                Email us about this &rarr;
              </a>
            </div>
          </ScrollReveal>
        ))}
      </div>

      <ScrollReveal delay={200}>
        <div class="mt-16 max-w-2xl mx-auto text-center text-[#666666] leading-relaxed">
          <p>
            Building a Brand Online is a fully remote team, so there's no office to visit — but there's also no phone tree to fight through. If you'd rather browse first, the <a href="/blog/" class="text-[#4361EE] hover:underline">blog</a> and <a href="/resources/" class="text-[#4361EE] hover:underline">free resources</a> answer the questions we hear most often.
          </p>
        </div>
      </ScrollReveal>
    </div>
  </section>
</Layout>
