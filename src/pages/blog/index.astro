---
import Layout from '@layouts/Layout.astro';
import BlogCard from '@components/BlogCard.astro';
import ScrollReveal from '@components/ScrollReveal.astro';
import { getCollection } from 'astro:content';
import { getPostUrl } from '@utils/blog';

const posts = await getCollection('blog');
posts.sort((a: any, b: any) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const categories = [...new Set(posts.map((post: any) => post.data.category))].sort() as string[];
const categorySlug = (name: string) => name.toLowerCase().replace(/\s+/g, '-');

const siteUrl = 'https://buildingabrandonline.com';
const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/blog/' },
];
const blogSchema = {
  '@type': 'Blog',
  '@id': `${siteUrl}/blog/#blog`,
  name: 'Building a Brand Online Blog',
  url: `${siteUrl}/blog/`,
  description:
    'Digital marketing tips, strategies, and guides to help you build a thriving online brand.',
  publisher: { '@id': `${siteUrl}/#organization` },
  blogPost: posts.map((post: any) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.excerpt,
    url: `${siteUrl}${getPostUrl(post)}`,
    datePublished: post.data.pubDate.toISOString(),
    author: { '@type': 'Person', name: post.data.author },
  })),
};
---

<Layout
  title="Blog - Building a Brand Online"
  description="Your go-to resource for mastering digital marketing, from SEO and email to social media and influencer marketing, and building a thriving online brand."
  breadcrumbs={breadcrumbs}
  jsonLd={blogSchema}
>
  <!-- Page Header -->
  <section class="pt-32 pb-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold" style="font-family: 'Noto Sans Display', ui-sans-serif, system-ui, sans-serif;">
        Your <em class="italic">Marketing</em> Journey Starts Here
      </h1>
      <p class="mt-4 text-[#666666] max-w-2xl text-lg">
        Welcome to Building a Brand Online's blog, your go-to resource for mastering digital marketing and building a thriving online brand.
      </p>
    </div>
  </section>

  <!-- Blog Grid -->
  <section class="pb-20 md:pb-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header Row -->
      <ScrollReveal>
        <div class="mb-12">
          <h2 class="text-3xl font-bold text-[#1A1A1A]">Latest Insights</h2>
          <p class="mt-2 text-[#666666]">Explore our newest marketing articles to boost your online brand.</p>
          <div class="flex flex-wrap gap-2 mt-6">
            {categories.map((category) => (
              <a
                href={`/blog/category/${categorySlug(category)}/`}
                class="px-4 py-1.5 rounded-full border border-[#E5E5E5] text-sm text-[#666666] hover:border-[#4361EE] hover:text-[#4361EE] transition-colors"
              >
                {category}
              </a>
            ))}
          </div>
        </div>
      </ScrollReveal>

      <!-- Posts Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {posts.map((post: any) => (
          <ScrollReveal delay={100}>
            <BlogCard
              title={post.data.title}
              category={post.data.category}
              excerpt={post.data.excerpt}
              image={post.data.image}
              href={getPostUrl(post)}
              variant="light"
              pubDate={post.data.pubDate.toISOString()}
            />
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>
</Layout>
