---
import Layout from '@layouts/Layout.astro';
import StatCounter from '@components/StatCounter.astro';
import ScrollReveal from '@components/ScrollReveal.astro';
import Button from '@components/Button.astro';

const siteUrl = 'https://buildingabrandonline.com';
const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'About', path: '/about/' },
];
const aboutSchema = {
  '@type': 'AboutPage',
  name: 'About Building a Brand Online',
  url: `${siteUrl}/about/`,
  description:
    'The story of Building a Brand Online: teaching entrepreneurs practical digital marketing since 2012.',
  about: { '@id': `${siteUrl}/#organization` },
};
---

<Layout
  title="About Us - Building a Brand Online"
  description="Building a Brand Online has taught practical digital marketing since 2012. Meet founder Dana Whitfield and learn how we help entrepreneurs build lasting brands."
  breadcrumbs={breadcrumbs}
  jsonLd={aboutSchema}
>
  <!-- Hero Section -->
  <section class="pt-32 pb-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Left — Text -->
        <div>
          <h1 class="text-4xl md:text-5xl font-bold text-[#1A1A1A] max-w-xl" style="font-family: 'Noto Sans Display', ui-sans-serif, system-ui, sans-serif;">
            Teaching Online Branding Since 2012
          </h1>
          <p class="mt-6 text-lg text-[#666666] leading-relaxed max-w-xl">
            Building a Brand Online started as a scrappy marketing blog: spontaneous interviews with people like <a href="/garyvee-interview/" class="text-[#4361EE] hover:underline">Gary Vaynerchuk</a>, giant resource lists for <a href="/MusiciansEmpowered/top-100-music-industry-blogs-2/" class="text-[#4361EE] hover:underline">musicians</a> and bloggers, and honest notes on what was working. Over a decade later, the mission hasn't changed: give entrepreneurs the marketing skills that agencies charge thousands for, in a form they can actually use.
          </p>

          <!-- Stats -->
          <div class="grid grid-cols-2 gap-6 mt-10">
            <StatCounter value={14} label="Years teaching online branding" />
            <StatCounter value={4800} suffix="+" label="Students through our courses" />
            <StatCounter value={300} suffix="+" label="Articles and guides published" />
            <StatCounter value={12000} suffix="+" label="Newsletter readers" />
          </div>
        </div>

        <!-- Right — Image -->
        <ScrollReveal delay={200}>
          <div class="relative">
            <img
              src="/images/about/about-mission.jpg"
              alt="Professional team in modern meeting room"
              class="rounded-lg w-full h-auto object-cover shadow-lg"
              loading="lazy"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <div class="hidden rounded-lg w-full aspect-[4/3] bg-gradient-to-br from-[#4361EE]/20 to-[#3A0CA3]/20 items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#4361EE" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
            </div>
          </div>
        </ScrollReveal>
      </div>
    </div>
  </section>

  <!-- Story Section -->
  <section class="py-20 md:py-28 bg-white border-t border-[#F0F0F0]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-[#1A1A1A]" style="font-family: 'Noto Sans Display', ui-sans-serif, system-ui, sans-serif;">How We Got Here</h2>
      <div class="mt-6 space-y-5 text-[#666666] leading-relaxed text-lg">
        <p>
          In 2012, "building a brand online" mostly meant having a Facebook page and hoping for the best. We were figuring it out in public: blogging daily, testing every platform, and interviewing anyone who'd built a real audience. Some of those early pieces, like our <a href="/garyvee-interview/" class="text-[#4361EE] hover:underline">fifteen-minute Skype interview with Gary Vaynerchuk</a>, still hold up today.
        </p>
        <p>
          As the audience grew, the questions kept repeating: How do I get found on Google? How do I turn readers into customers? So we turned the answers into structured <a href="/training/" class="text-[#4361EE] hover:underline">training programs</a>, <a href="/resources/" class="text-[#4361EE] hover:underline">free templates</a>, and hands-on <a href="/services/" class="text-[#4361EE] hover:underline">branding services</a> for people who'd rather have it done with them than alone.
        </p>
        <p>
          What we won't do: promise overnight results, sell you a "secret system," or pad courses with filler to justify a bigger price tag. Brands are built the same way they were in 2012 — by showing up consistently with something worth paying attention to. We just help you do it faster and with fewer wrong turns.
        </p>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="py-20 md:py-28 bg-[#F5F5F5]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <p class="text-sm uppercase tracking-widest text-[#999999] mb-4">Who's Behind This</p>
        <h2 class="text-3xl md:text-4xl font-bold text-[#1A1A1A]" style="font-family: 'Noto Sans Display', ui-sans-serif, system-ui, sans-serif;">Meet the Founder</h2>
      </ScrollReveal>

      <!-- Team Member -->
      <ScrollReveal delay={100}>
        <div class="mt-12 flex flex-col md:flex-row items-start gap-6 bg-white rounded-lg p-8 shadow-sm max-w-2xl">
          <img
            src="/images/avatars/avatar-jane.jpg"
            alt="Dana Whitfield, founder of Building a Brand Online"
            class="w-28 h-28 md:w-32 md:h-32 rounded-full object-cover border-4 border-[#E5E5E5] flex-shrink-0"
            loading="lazy"
          />
          <div>
            <h3 class="text-xl font-bold text-[#1A1A1A]">Dana Whitfield</h3>
            <p class="text-sm text-[#999999] mt-1">Founder &amp; Brand Strategist</p>
            <p class="text-[#666666] mt-3 leading-relaxed">
              Dana spent the early 2010s doing marketing for musicians and small businesses that couldn't afford an agency, and started this site to write down everything that worked. Fifteen years on, she still writes most of the training material herself and answers reader emails personally. Her rule for every lesson: if a busy founder can't act on it this week, it doesn't ship.
            </p>
            <div class="mt-4">
              <Button variant="primary-outline" size="sm" href="/contact/">Say Hello</Button>
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>
</Layout>
