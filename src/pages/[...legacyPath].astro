---
import BlogPostPage from '@components/BlogPostPage.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => post.data.legacyUrl)
    .map((post) => ({
      params: {
        legacyPath: post.data.legacyUrl!.replace(/^\//, '').replace(/\/$/, ''),
      },
      props: { post },
    }));
}

const { post } = Astro.props;
const canonicalPath = post.data.legacyUrl!;
---

<BlogPostPage post={post} canonicalPath={canonicalPath} />
