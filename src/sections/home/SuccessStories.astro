---
import { testimonials } from '@data/testimonials';
---

<section class="py-20 md:py-28 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-[#1A1A1A] mb-4 font-display">Success Stories</h2>
      <p class="text-gray-600 max-w-2xl mx-auto">
        What students say after putting the training to work.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-4xl mx-auto">
      {testimonials.map((testimonial) => (
        <figure class="text-center">
          <p class="text-6xl font-serif text-gray-200 leading-none mb-2" aria-hidden="true">&ldquo;</p>
          <blockquote class="text-gray-800 italic mb-6 leading-relaxed">
            {testimonial.quote}
          </blockquote>
          <figcaption class="flex flex-col items-center">
            <img src={testimonial.avatar} alt={testimonial.name} class="w-16 h-16 rounded-full object-cover mb-3" loading="lazy" />
            <p class="font-semibold text-[#1A1A1A]">{testimonial.name}</p>
            <p class="text-sm text-gray-600">{testimonial.role}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
