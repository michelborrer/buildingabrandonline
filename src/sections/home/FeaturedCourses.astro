---
import { courses } from '@data/courses';
---

<section class="py-20 md:py-28 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-center text-[#1A1A1A] mb-4 font-display">
      Featured Courses
    </h2>
    <p class="text-gray-600 max-w-2xl mx-auto text-center mb-16">
      Four core skills, taught in plain English. Pick the one your brand needs most right now.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      {courses.map((course) => (
        <a href="/training/" class="block bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group">
          <div class="aspect-[4/3] overflow-hidden">
            <img src={course.image} alt={course.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-6 text-center">
            <h3 class="text-lg font-bold text-[#1A1A1A] mb-2 group-hover:text-[#4361EE] transition-colors">{course.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{course.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
