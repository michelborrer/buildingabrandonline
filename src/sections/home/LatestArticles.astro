---
import { getCollection } from 'astro:content';
import { getPostUrl } from '@utils/blog';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<section class="py-20 md:py-28 lg:py-32 bg-[#0A0A0A]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header row -->
    <div class="flex flex-col sm:flex-row items-start sm:items-end justify-between mb-12 gap-4">
      <div>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-2 font-display">Latest Articles</h2>
        <p class="text-gray-400">Fresh, field-tested marketing advice from the blog.</p>
      </div>
      <a href="/blog/" class="border border-white text-white px-5 py-2 rounded-md text-sm font-medium hover:bg-white hover:text-[#0A0A0A] transition-all duration-200 shrink-0">
        View All
      </a>
    </div>

    <!-- Blog grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {posts.map((post) => (
        <a href={getPostUrl(post)} class="group block rounded-lg overflow-hidden bg-[#111111] hover:bg-[#1A1A1A] transition-colors duration-300">
          <div class="aspect-[16/10] overflow-hidden">
            <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-6">
            <span class="text-xs uppercase tracking-wider text-[#4361EE] font-semibold">{post.data.category}</span>
            <h3 class="text-lg font-bold text-white mt-2 group-hover:text-[#4361EE] transition-colors leading-snug">
              {post.data.title}
            </h3>
            <p class="text-sm text-gray-400 mt-2 line-clamp-2">{post.data.excerpt}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
